<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FindYourHome.ViewModels"
             x:Class="FindYourHome.Views.AddEditHousePage">
    <StackLayout Padding="10" Spacing="8">
        <Entry Placeholder="Titre" Text="{Binding House.Title}"/>
        <Entry Placeholder="Adresse" Text="{Binding House.Address}"/>
        <Editor Placeholder="Description" Text="{Binding House.Description}" HeightRequest="100"/>
        <Entry Placeholder="Prix" Text="{Binding House.Price}" Keyboard="Numeric"/>
        <Button Text="Enregistrer" Command="{Binding SaveCommand}"/>
    </StackLayout>
</ContentPage>
