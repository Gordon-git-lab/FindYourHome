<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FindYourHome.ViewModels"
             x:Class="FindYourHome.Views.HomePage">
    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>

    <CollectionView ItemsSource="{Binding Houses}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="10" Padding="10">
                    <StackLayout>
                        <Label Text="{Binding Title}" FontAttributes="Bold" />
                        <Label Text="{Binding Address}" FontSize="12" />
                        <Label Text="{Binding Price, StringFormat='Prix: {0:C}'}" FontSize="14" />
                    </StackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
